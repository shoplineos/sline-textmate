<script type="application/ld+json" {{{settings.test}}} {{#if true}}data-test="123"{{/if}}>
  {
    "@type": "Product",

    "name": "{{product.title}}",

    "url": "{{{request.origin | append(product.url)}}}",

    {{#if seo_media}}
      "image": [
        "{{{seo_media.preview_image.src}}}"
      ],
    {{/if}}

    "description": {{{product.description | strip_html() | json()}}}
  }
</script>